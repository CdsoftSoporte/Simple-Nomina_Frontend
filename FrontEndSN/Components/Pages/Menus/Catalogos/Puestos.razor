@attribute [Authorize]
@page "/puestos"
@using DevExpress.Blazor
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@rendermode InteractiveServer
<PageTitle>Catálogo de Puestos</PageTitle>

<div class="dashboard-container page-header-fade fade-in-all">
    <header class="dashboard-header d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center">
            <button class="btn btn-back-custom me-3"
                    @onclick='() => Nav.NavigateTo("/menu_catalogos")'
                    title="Regresar a Catálogos">
                <i class="bi bi-chevron-left"></i>
            </button>
            <div class="text-start">
                <h1 class="m-0">Puestos</h1>
                <p class="text-muted m-0">Configuración de puestos por departamento</p>
            </div>
        </div>
        <DxButton Text="Nuevo Puesto"
                  Click="() => MostrarModal()"
                  RenderStyle="ButtonRenderStyle.Primary"
                  IconCssClass="bi bi-plus-circle-fill"
                  CssClass="shadow-sm" />
    </header>

    <div class="card shadow-sm border-0 p-3 fade-in-all w-100">
        <DxGrid Data="@PuestosList"
                PageSize="10"
                ShowFilterRow="false"
                TextAlignment="GridTextAlignment.Center"
                HighlightRowOnHover="true"
                CssClass="w-100">
            <Columns>
                @* Sin Width fijo = se distribuyen proporcionalmente *@
                <DxGridDataColumn FieldName="Nombre" Caption="Nombre" />
                <DxGridDataColumn FieldName="Descripcion" Caption="Descripción">
                    <CellDisplayTemplate>
                        <span style="white-space: normal; word-break: break-word;">@context.Value</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="IdDepartamento" Caption="Departamento">
                    <CellDisplayTemplate>
                        @{
                            var p = (Puesto)context.DataItem;
                            var depto = DeptosList.FirstOrDefault(d => d.Id == p.IdDepartamento);
                        }
                        <span>@(depto?.Nombre ?? "-")</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>

       
                <DxGridDataColumn FieldName="SalarioBase" Caption="Salario Base" Width="130px" DisplayFormat="C2" />
                <DxGridDataColumn FieldName="Activo" Caption="Activo" Width="70px" />
                <DxGridDataColumn Caption="Acciones" Width="80px" TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate>
                        @{
                            var item = (Puesto)context.DataItem;
                        }
                        <div class="d-flex justify-content-center gap-2">
                            <button class="btn btn-outline-primary btn-sm border-0 btn-icon-custom"
                                    @onclick="() => MostrarModal(item)">
                                <i class="bi bi-pencil-square"></i>
                            </button>
                        </div>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
            <EmptyDataAreaTemplate>
                <div class="empty-grid-container">
                    <div class="empty-icon-wrapper">
                        <i class="bi bi-briefcase-fill"></i>
                    </div>
                    <h4>Sin puestos registrados</h4>
                    <p>Registre al menos un puesto.</p>
                </div>
            </EmptyDataAreaTemplate>
        </DxGrid>
    </div>
</div>


@* Modal *@
<DxWindow @bind-Visible="@isModalVisible"
          HeaderText="@(PuestoModel.Id == 0 ? "Nuevo Puesto" : "Editar Puesto")"
          Width="550px"
          AllowResize="false"
          ShowCloseButton="true"
          CloseOnEscape="true"
          HeaderCssClass="bg-primary text-white"
          Modal="true">
    <BodyTextTemplate>
        <EditForm EditContext="@editContext" Context="formContext"style="width:100%;">
            <DataAnnotationsValidator />
            <div class="p-1 w-100">
                <div class="mb-3">
                    <label class="form-label fw-bold">Nombre:</label>
                    <DxTextBox @bind-Text="@PuestoModel.Nombre"
                               NullText="Ej. Desarrollador Senior"
                               CssClass="custom-input" />
                    <ValidationMessage For="@(() => PuestoModel.Nombre)" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Descripción:</label>
                    <DxTextBox @bind-Text="@PuestoModel.Descripcion"
                               NullText="Ej. Desarrollo y mantenimiento de sistemas"
                               CssClass="custom-input" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Departamento:</label>
                    <DxComboBox Data="@DeptosList"
                                @bind-Value="@PuestoModel.IdDepartamento"
                                TextFieldName="Nombre"
                                ValueFieldName="Id"
                                CssClass="white-border-input" />
                    <ValidationMessage For="@(() => PuestoModel.IdDepartamento)" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Salario Base:</label>
                    <DxSpinEdit @bind-Value="@PuestoModel.SalarioBase"
                                MinValue="0m"
                                DisplayFormat="C2"
                                CssClass="white-border-input" />
                    <ValidationMessage For="@(() => PuestoModel.SalarioBase)" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Estatus:</label>
                    <DxComboBox Data="@estatusOpciones"
                                @bind-Value="@PuestoModel.Activo"
                                TextFieldName="Texto"
                                ValueFieldName="Valor"
                                CssClass="white-border-input" />
                </div>
                <div style="margin-top:10px">
                    <DxButton Text="Cancelar"
                              Click="() => isModalVisible = false"
                              RenderStyle="ButtonRenderStyle.Secondary" />
                    <DxButton Text="Guardar Cambios"
                              Click="Guardar"
                              RenderStyle="ButtonRenderStyle.Primary" />
                </div>
            </div>
        </EditForm>
    </BodyTextTemplate>
</DxWindow>