@attribute [Authorize]
@page "/Turnos"
@using DevExpress.Blazor
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@rendermode InteractiveServer
<PageTitle>Catálogo de Turnos</PageTitle>

<div class="dashboard-container page-header-fade fade-in-all">
    <header class="dashboard-header d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center">
            <button class="btn btn-back-custom me-3"
                    @onclick='() => Nav.NavigateTo("/menu_catalogos")'
                    title="Regresar a Catálogos">
                <i class="bi bi-chevron-left"></i>
            </button>
            <div class="text-start">
                <h1 class="m-0">Turnos</h1>
                <p class="text-muted m-0">Catálogo de turnos</p>
            </div>
        </div>
        <DxButton Text="Nuevo Turno"
                  Click="() => MostrarModal()"
                  RenderStyle="ButtonRenderStyle.Primary"
                  IconCssClass="bi bi-plus-circle-fill"
                  CssClass="shadow-sm" />
    </header>
    @if (cargando)
    {
        <div class="d-flex justify-content-center align-items-center p-5">
            <div class="text-center">
                <div class="spinner-custom mb-3"></div>
                <p class="text-muted">Cargando datos...</p>
            </div>
        </div>
    }
    else{
    <div class="card shadow-sm border-0 p-3 fade-in-all w-100">
        <DxGrid Data="@TurnosList"
                PageSize="10"
                ShowFilterRow="false"
                TextAlignment="GridTextAlignment.Center"
                    HighlightRowOnHover="true"
                CssClass="w-100">
            <Columns>

                <DxGridDataColumn FieldName="Descripcion" Caption="Descripción">
                    <CellDisplayTemplate>
                        <span style="white-space: normal; word-break: break-word;">@context.Value</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="hora_entrada" Caption="Hora Entrada" Width="130px"  />
                <DxGridDataColumn FieldName="hora_salida" Caption="Hora Salida" Width="130px"  />
                <DxGridDataColumn FieldName="dias_descanso" Caption="Dias de descanso" Width="130px"  />
                <DxGridDataColumn FieldName="Activo" Caption="Activo" Width="70px" />
                <DxGridDataColumn Caption="Acciones" Width="80px" TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate>
                        @{
                            var item = (Turno)context.DataItem;
                        }
                        <div class="d-flex justify-content-center gap-2">
                            <button class="btn btn-outline-primary btn-sm border-0 btn-icon-custom"
                                    @onclick="() => MostrarModal(item)">
                                <i class="bi bi-pencil-square"></i>
                            </button>
                        </div>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
            <EmptyDataAreaTemplate>
                <div class="empty-grid-container">
                    <div class="empty-icon-wrapper">
                        <i class="bi bi-clock-fill"></i>
                    </div>
                    <h4>Sin turnos registrados</h4>
                    <p>Registre al menos un turno.</p>
                </div>
            </EmptyDataAreaTemplate>
        </DxGrid>
    </div>
    }
</div>


@* Modal *@
<DxWindow @bind-Visible="@isModalVisible"
          HeaderText="@(TurnosModel.Id == 0 ? "Nuevo Turno" : "Editar Turno")"
          Width="550px"
          AllowResize="false"
          ShowCloseButton="true"
          CloseOnEscape="true"
          HeaderCssClass="bg-primary text-white"
          Modal="true">
    <BodyTextTemplate>
        <EditForm EditContext="@editContext" Context="formContext" style="width:100%;">
            <DataAnnotationsValidator />
            <div class="p-1 w-100">

                <div class="mb-3">
                    <label class="form-label fw-bold">Descripción:</label>
                    <DxTextBox @bind-Text="@TurnosModel.Descripcion"
                               NullText="Ej. Desarrollo y mantenimiento de sistemas"
                               CssClass="custom-input" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Hora de Entrada:</label>
                    <DxTimeEdit @bind-Time="@TurnosModel.hora_entrada"
                                Format="@DisplayFormat"
                                CssClass="custom-input"
                                InputId="teDisplayFormat" />
                  
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Hora de Salida:</label>
                    <DxTimeEdit @bind-Time="@TurnosModel.hora_salida"
                                Format="@DisplayFormat"
                                CssClass="custom-input"
                                InputId="teDisplayFormat" />

                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Días de Descanso:</label>
                    <div class="d-flex flex-wrap gap-3 mt-1">
                        @foreach (var dia in diasSemana)
                        {
                            <DxCheckBox Checked="@dia.Marcado"
                                        CheckedChanged="@((bool v) => OnDiaDescansoChanged(dia, v))"
                                        CheckedExpression="@(() => dia.Marcado)"
                                        LabelPosition="LabelPosition.Right">
                                @dia.Valor
                            </DxCheckBox>
                        }
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Estatus:</label>
                    <DxComboBox Data="@estatusOpciones"
                                @bind-Value="@TurnosModel.Activo"
                                TextFieldName="Texto"
                                ValueFieldName="Valor"
                                CssClass="white-border-input" />
                </div>
                <div style="margin-top:10px">
                    <DxButton Text="Cancelar"
                              Click="() => isModalVisible = false"
                              RenderStyle="ButtonRenderStyle.Secondary" />
                    <DxButton Text="Guardar Cambios"
                              Click="Guardar"
                              RenderStyle="ButtonRenderStyle.Primary" />
                </div>
            </div>
        </EditForm>
    </BodyTextTemplate>
</DxWindow>
